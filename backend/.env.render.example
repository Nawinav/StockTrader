# ============================================================
#  Stock Trading App - Backend Environment Variables (Render Free)
#  Copy values into Render -> Service -> Environment.
#  This preset keeps the app on a fully free deployment path:
#  - mock market data
#  - stub analyzer
#  - paper trading only
# ============================================================

# ----- App -------------------------------------------------------
ENVIRONMENT=production

# ----- Cache / refresh ------------------------------------------
# Higher TTL reduces backend work on Render free tier.
SUGGESTIONS_TTL_SECONDS=600
ANALYZER_TTL_SECONDS=60

# ----- Frontend integration -------------------------------------
# If you use the default *.vercel.app URL, it is already allowed by regex.
# Set CORS_ORIGINS only if you later move the frontend to a custom domain.
CORS_ORIGINS=
APP_FRONTEND_URL=https://your-project-name.vercel.app

# ----- Free deployment mode -------------------------------------
DATA_PROVIDER=mock
PAPER_TRADING=true
ANALYZER_PROVIDER=stub

# ----- Persistence ----------------------------------------------
# Render free services have an ephemeral filesystem.
WATCHLIST_PATH=watchlist.json

# ----- Upstox (leave blank for the free deploy path) ------------
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=
UPSTOX_INSTRUMENTS_PATH=
UPSTOX_MOBILE=
UPSTOX_PIN=
UPSTOX_TOTP_SECRET=

# ----- Notifications (optional) ---------------------------------
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# ----- Claude / Anthropic (leave blank for free deploy path) ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- Trading defaults -----------------------------------------
DEFAULT_CAPITAL_INR=100000
DEFAULT_RISK_PCT=1.0
DEFAULT_MAX_DAILY_LOSS_PCT=3.0
