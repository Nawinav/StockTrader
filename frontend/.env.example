# ============================================================
#  Stock Trading App - Frontend Environment Variables (Local Dev)
#  Copy this file to .env.local for local development.
#  For Vercel production, start from .env.vercel.example instead.
#  NEVER commit .env.local to version control.
# ============================================================

# URL where the FastAPI backend is reachable. No trailing slash.
# Local dev:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Production example:
# NEXT_PUBLIC_API_BASE_URL=https://your-service-name.onrender.com
