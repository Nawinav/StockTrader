# ============================================================
#  Stock Trading App - Backend Environment Variables (Local Dev)
#  Copy this file to .env for local development.
#  For free Render deployment, start from .env.render.example instead.
#  NEVER commit .env to version control.
# ============================================================

# ----- App -------------------------------------------------------
ENVIRONMENT=development
# For Render production, use ENVIRONMENT=production.

# ----- Cache TTL -------------------------------------------------
SUGGESTIONS_TTL_SECONDS=300
# Increase to 600 on Render free tier to reduce compute load/cold starts.

# ----- CORS ------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# For local dev, keep localhost.
# Default *.vercel.app domains are already allowed by regex in app/main.py.
# Only set your production domain here if you use a custom frontend domain.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production example:
# CORS_ORIGINS=https://your-app-name.com

# ----- Data Provider ---------------------------------------------
# "mock"   -> synthetic OHLCV data, no credentials needed
# "upstox" -> live NSE data via Upstox API (requires credentials below)
DATA_PROVIDER=mock
# Set to "upstox" once Upstox credentials are configured.

# ----- Upstox Credentials ----------------------------------------
# Get these from https://upstox.com/developer/ -> My Apps -> Create App
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# Redirect URI - MUST exactly match what you registered in Upstox My Apps.
# Local dev:    http://localhost:8000/auth/upstox/callback
# Production:   https://your-render-service.onrender.com/auth/upstox/callback
UPSTOX_REDIRECT_URI=http://localhost:8000/auth/upstox/callback

# Optional: paste a fresh daily token here to skip the OAuth dance.
# The callback at /auth/upstox/callback writes this automatically.
UPSTOX_ACCESS_TOKEN=

# Optional: path to a local Upstox instruments CSV if the symbol map is stale.
UPSTOX_INSTRUMENTS_PATH=

# ----- Upstox Headless Auto-Login --------------------------------
# Fill these to enable the daily OTP-based auto-login flow.
# UPSTOX_TOTP_SECRET is the base32 key shown when setting up 2FA:
#   Upstox -> Settings -> My Profile -> Two Factor Auth -> "Enter key manually"
UPSTOX_MOBILE=
UPSTOX_PIN=
UPSTOX_TOTP_SECRET=

# ----- Push Notifications (ntfy.sh) ------------------------------
# Free, no account needed. Install the "ntfy" app -> subscribe to this topic.
# Use a long random string for privacy (e.g. naveen-trading-a8f3k2x9)
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# ----- Frontend URL (used in push notification deep-links) -------
APP_FRONTEND_URL=http://localhost:3000
# Production example:
# APP_FRONTEND_URL=https://your-app-name.vercel.app

# ----- Safety ----------------------------------------------------
# ALWAYS keep true until you are fully confident in the live trading setup.
PAPER_TRADING=true

# ----- Persistence -----------------------------------------------
WATCHLIST_PATH=watchlist.json
# NOTE: On Render free tier the filesystem is EPHEMERAL - files written at
# runtime (watchlist.json, trading_state.json, upstox_token.json) are lost
# on every restart/redeploy. This is fine for paper trading (state resets
# to defaults), but means you re-login to Upstox after each restart.

# ----- Intraday Analyzer (Claude AI) -----------------------------
# "stub"      -> deterministic rule-based response (no API cost, works offline)
# "anthropic" -> real Claude API call (requires ANTHROPIC_API_KEY)
ANALYZER_PROVIDER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANALYZER_TTL_SECONDS=60

# ----- Default Trading Parameters --------------------------------
DEFAULT_CAPITAL_INR=100000
DEFAULT_RISK_PCT=1.0
DEFAULT_MAX_DAILY_LOSS_PCT=3.0
